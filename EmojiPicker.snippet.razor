    private IEnumerable<string> FilteredEmojis
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(_emojiSearch))
                return EmojiCategories.SelectMany(c => c.Emojis)
                                      .Distinct()
                                      .Where(e => e.Contains(_emojiSearch.Trim()))
                                      .Take(64);
            return EmojiCategories.First(c => c.Key == _emojiTab).Emojis;
        }
    }

    private void ToggleEmojiPicker() => _emojiOpen = !_emojiOpen;
    private void SetEmojiTab(string tab) { _emojiTab = tab; _emojiSearch = ""; }
    private void OnEmojiSearch(ChangeEventArgs e) => _emojiSearch = e.Value?.ToString() ?? "";

    private async Task InsertEmoji(string emoji)
    {
        await JS.InvokeVoidAsync("RichTextEditor.insertText", _id, emoji);
        await OnInput();

        if (!_recentEmojis.Contains(emoji)) _recentEmojis.Insert(0, emoji);
        if (_recentEmojis.Count > 8) _recentEmojis.RemoveAt(8);

        // keep picker open so user can insert multiple
        StateHasChanged();
    }
}
