@* ── Add this block inside your .toolbar div, after the tb-sep before the tb-ai button ── *@

<div class="tb-sep"></div>

<div class="emoji-picker-wrap" id="emojiWrap-@_id">
    <button type="button" class="tb-emoji-btn @(_emojiOpen ? "open" : "")"
            id="emojiToggle-@_id"
            @onclick="ToggleEmojiPicker"
            title="Insert emoji">
        <span style="font-size:15px">😊</span>
        <span>Emoji</span>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
    </button>

    @if (_emojiOpen)
    {
        <div class="emoji-picker" id="emojiPicker-@_id" @onclick:stopPropagation>

            <div class="picker-search">
                <input type="text"
                       placeholder="Search emoji..."
                       @bind="_emojiSearch"
                       @bind:event="oninput"
                       @oninput="OnEmojiSearch" />
            </div>

            <div class="picker-tabs">
                @foreach (var cat in EmojiCategories)
                {
                    <button type="button"
                            class="tab-btn @(_emojiTab == cat.Key ? "active" : "")"
                            @onclick="() => SetEmojiTab(cat.Key)">
                        @cat.Icon @cat.Label
                    </button>
                }
            </div>

            <div class="picker-grid">
                @foreach (var emoji in FilteredEmojis)
                {
                    var e = emoji;
                    <button type="button" class="e-btn" title="@e" @onclick="() => InsertEmoji(e)">@e</button>
                }
            </div>

            @if (_recentEmojis.Any())
            {
                <div class="picker-recent-label">Recently used</div>
                <div class="picker-recent-row">
                    @foreach (var emoji in _recentEmojis)
                    {
                        var e = emoji;
                        <button type="button" class="e-btn" @onclick="() => InsertEmoji(e)">@e</button>
                    }
                </div>
            }

        </div>
    }
</div>

@* ── Add these fields to your @code block ── *@
