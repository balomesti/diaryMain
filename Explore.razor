@page "/explore"
@using System.Linq
@implements IDisposable
@inject DiaryService DiaryService
@inject IJSRuntime JS

<PageTitle>Explore</PageTitle>

<section class="explore-hero">
    <h1>Explore</h1>
    <p>Explore news posts from the admin team.</p>
</section>

<section class="explore-feed">
    @if (!string.IsNullOrEmpty(loadError))
    {
        <div class="explore-error" role="alert">@loadError</div>
    }
    else if (isLoading)
    {
        <p class="explore-loading">Loading...</p>
    }
    else if (updates.Count == 0)
    {
        <p class="explore-empty">No explore posts found.</p>
    }
    else
    {
        @foreach (var item in updates)
        {
            <article class="explore-post-card">

                <!-- ── Author row ── -->
                <div class="explore-post-author-row">
                    <div class="explore-post-avatar">@GetAvatarInitials(item.Author)</div>
                    <div class="explore-post-author-meta">
                        <span class="explore-post-author-name">@item.Author</span>
                        <span class="explore-post-timestamp">@TimeAgo(item.CreatedAt)</span>
                    </div>
                </div>

                <!-- ── Gallery ── -->
                <div class="explore-post-gallery" id="gallery-@item.Id"
                     style="background: @item.GalleryBackgrounds[item.GalleryIndex % item.GalleryBackgrounds.Length]">
                    @if (string.IsNullOrWhiteSpace(item.ImageUrl) && string.IsNullOrWhiteSpace(item.VideoUrl))
                    {
                        <div class="explore-post-gallery-placeholder">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                                <rect x="3" y="3" width="18" height="18" rx="3"/>
                                <circle cx="8.5" cy="8.5" r="1.5"/>
                                <path d="M21 15l-5-5L5 21"/>
                            </svg>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(item.VideoUrl))
                    {
                        <video class="explore-post-video" controls>
                            <source src="@item.VideoUrl" type="video/mp4">
                            Your browser does not support the video tag.
                        </video>
                    }
                    else
                    {
                        @foreach (var (url, index) in item.ImageUrls.Select((u, i) => (u, i)))
                        {
                            <img class="explore-post-gallery-img @(index == item.GalleryIndex ? "active" : "")"
                                 src="@url" alt="@item.Title" />
                        }
                    }

                    @if (item.ImageUrls.Count > 1)
                    {
                        <span class="explore-post-gallery-count">@(item.GalleryIndex + 1) / @item.ImageUrls.Count</span>
                        <div class="explore-post-gallery-dots">
                            @for (int i = 0; i < item.ImageUrls.Count; i++)
                            {
                                var index = i;
                                <div class="explore-post-gallery-dot @(index == item.GalleryIndex ? "active" : "")"
                                     @onclick="() => SetSlide(item, index)"></div>
                            }
                        </div>
                        <button class="explore-post-gallery-nav prev" @onclick="() => PrevSlide(item)">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="M15 18l-6-6 6-6"/>
                            </svg>
                        </button>
                        <button class="explore-post-gallery-nav next" @onclick="() => NextSlide(item)">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="M9 18l6-6-6-6"/>
                            </svg>
                        </button>
                    }
                </div>

                <!-- ── Post body ── -->
                <div class="explore-post-body">
                    <h2 class="explore-post-title">@item.Title</h2>
                    <p class="explore-post-caption @(item.IsExpanded ? "" : "clamped")">@item.Description</p>
                    @if (item.NeedsReadMore)
                    {
                        <button class="explore-post-read-more" @onclick="() => ToggleReadMore(item)">
                            @(item.IsExpanded ? "Show less" : "Read more")
                        </button>
                    }
                </div>

                <!-- ── Reaction bar ── -->
                <div class="reaction-bar">
                    @foreach (var reaction in new[] {
                        ("heart", "❤️"), ("fire", "🔥"), ("bulb", "💡"), ("clap", "👏")
                    })
                    {
                        var key = reaction.Item1;
                        var emoji = reaction.Item2;
                        var isReacted = item.Reacted.Contains(key);
                        <button class="reaction-btn @key @(isReacted ? "reacted" : "")"
                                @onclick="() => ToggleReaction(item, key)">
                            <span class="reaction-emoji">@emoji</span>
                            <span class="reaction-count">@item.ReactionCounts.GetValueOrDefault(key)</span>
                        </button>
                    }

                    <div class="action-right">
                        <button class="icon-btn @(item.ShowComments ? "active" : "")"
                                @onclick="() => ToggleComments(item)">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                            </svg>
                            <span>@item.Comments.Count</span>
                        </button>
                        <button class="icon-btn @(item.ShareCopied ? "share-copied" : "")"
                                @onclick="() => HandleShare(item)">
                            @if (item.ShareCopied)
                            {
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                            }
                            else
                            {
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="18" cy="5" r="3"/>
                                    <circle cx="6" cy="12" r="3"/>
                                    <circle cx="18" cy="19" r="3"/>
                                    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                                    <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                                </svg>
                            }
                        </button>
                    </div>
                </div>

                <!-- ── Comments section ── -->
                @if (item.ShowComments)
                {
                    <div class="comments-section">
                        <hr class="divider" />

                        @if (item.Comments.Count > 0)
                        {
                            <div class="comments-list">
                                @foreach (var (c, idx) in item.Comments.Select((c, i) => (c, i)))
                                {
                                    @if (idx < item.VisibleComments)
                                    {
                                        <div class="comment-row">
                                            @if (!string.IsNullOrEmpty(c.ProfileImg))
                                            {
                                                <img class="comment-avatar img-avatar" src="@c.ProfileImg" alt="@c.Author" />
                                            }
                                            else
                                            {
                                                <div class="comment-avatar">@GetAvatarInitials(c.Author)</div>
                                            }
                                            <div class="comment-bubble">
                                                <div class="comment-author">@c.Author</div>
                                                <div class="comment-text">@c.Text</div>
                                                <div class="comment-meta">
                                                    <span class="comment-time">@TimeAgo(c.CreatedAt)</span>
                                                    <button class="comment-like-btn @(c.Liked ? "liked" : "")"
                                                            @onclick="() => ToggleCommentLike(c)">
                                                        ♥ @c.LikeCount
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                            @if (item.Comments.Count > item.VisibleComments)
                            {
                                <button class="show-more-btn" @onclick="() => ShowMoreComments(item)">
                                    View @(item.Comments.Count - item.VisibleComments) more comment@(item.Comments.Count - item.VisibleComments == 1 ? "" : "s")
                                </button>
                            }
                        }

                        <!-- ── Comment input ── -->
                        <div class="comment-input-row">
                            @if (!string.IsNullOrEmpty(currentUser?.ProfileImg))
                            {
                                <img class="comment-input-avatar img-avatar" src="@currentUser.ProfileImg" alt="Me" />
                            }
                            else
                            {
                                <div class="comment-input-avatar">
                                    @GetAvatarInitials(currentUser?.DisplayName ?? "Me")
                                </div>
                            }

                            <div class="comment-input-wrap" id="emoji-anchor-@item.Id">
                                <input id="comment-input-@item.Id"
                                       placeholder="Write a comment…"
                                       value="@item.NewCommentText"
                                       @oninput="e => item.NewCommentText = e.Value?.ToString() ?? string.Empty"
                                       @onkeydown="async e => { if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(item.NewCommentText)) await AddComment(item); }" />

                                <!-- Emoji trigger -->
                                <button class="emoji-trigger-btn" type="button"
                                        @onclick="() => OpenEmojiPicker(item)">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10"/>
                                        <path d="M8 13s1.5 2 4 2 4-2 4-2"/>
                                        <line x1="9" y1="9" x2="9.01" y2="9"/>
                                        <line x1="15" y1="9" x2="15.01" y2="9"/>
                                    </svg>
                                </button>

                                <!-- Send -->
                                <button class="comment-send-btn"
                                        disabled="@string.IsNullOrWhiteSpace(item.NewCommentText)"
                                        @onclick="() => AddComment(item)">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2">
                                        <line x1="22" y1="2" x2="11" y2="13"/>
                                        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                                    </svg>
                                </button>
                            </div>
                        </div>

                    </div>
                }

            </article>
        }
    }
</section>

@code {
    private bool isLoading;
    private string loadError = "";
    private List<UpdateItem> updates = new();
    private CurrentUserDto? currentUser;
    private DotNetObjectReference<Explore>? _dotNetRef;

    protected override void OnInitialized()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        loadError = "";

        try { currentUser = await DiaryService.GetCurrentUserAsync(); } catch { }

        try
        {
            var items = await DiaryService.GetAdminListAsync<NewsPostDto>("api/Admin/news");

            updates = items
                .Select(n => new UpdateItem
                {
                    Id          = n.Id,
                    Title       = n.Title,
                    Description = n.Content,
                    Author      = n.Author,
                    CreatedAt   = n.CreatedAt,
                    ImageUrl    = n.ImageUrl,
                    VideoUrl    = n.VideoUrl,
                    ImageUrls   = string.IsNullOrWhiteSpace(n.ImageUrl)
                                    ? new List<string>()
                                    : new List<string> { n.ImageUrl },
                    NeedsReadMore = n.Content.Length > 280
                })
                .OrderByDescending(x => x.CreatedAt)
                .ToList();

            foreach (var item in updates)
            {
                try { item.ReactionCounts = await DiaryService.GetReactionCountsAsync(item.Id); } catch { }
                try { item.Reacted        = await DiaryService.GetUserReactionsAsync(item.Id); }  catch { }
                try
                {
                    var comments = await DiaryService.GetCommentsAsync(item.Id);
                    item.Comments = comments.Select(c => new CommentItem
                    {
                        Id         = c.Id,
                        Author     = c.Author,
                        ProfileImg = c.ProfileImg,
                        Text       = c.Text,
                        CreatedAt  = c.CreatedAt,
                        Liked      = c.Liked,
                        LikeCount  = c.LikeCount
                    }).ToList();
                }
                catch { }
            }
        }
        catch (Exception ex) { loadError = ex.Message; }
        finally { isLoading = false; }
    }

    // ── Gallery ────────────────────────────────────────────────

    private static readonly string[] GalleryBackgrounds = { "#b5c4b1", "#c4b5b5", "#b5b9c4" };

    private void SetSlide(UpdateItem item, int index)  => item.GalleryIndex = index;
    private void PrevSlide(UpdateItem item) =>
        item.GalleryIndex = (item.GalleryIndex - 1 + item.ImageUrls.Count) % item.ImageUrls.Count;
    private void NextSlide(UpdateItem item) =>
        item.GalleryIndex = (item.GalleryIndex + 1) % item.ImageUrls.Count;

    // ── Read more ──────────────────────────────────────────────

    private void ToggleReadMore(UpdateItem item) => item.IsExpanded = !item.IsExpanded;

    // ── Reactions ──────────────────────────────────────────────

    private async Task ToggleReaction(UpdateItem item, string key)
    {
        try
        {
            var result = await DiaryService.ToggleReactionAsync(item.Id, key);
            item.ReactionCounts = new Dictionary<string, int>
                { {"heart",0}, {"fire",0}, {"bulb",0}, {"clap",0} };
            foreach (var c in result.Counts)
                item.ReactionCounts[c.Type] = c.Count;

            if (result.Toggled && !item.Reacted.Contains(key)) item.Reacted.Add(key);
            else if (!result.Toggled)                          item.Reacted.Remove(key);
        }
        catch { }
    }

    // ── Share ──────────────────────────────────────────────────

    private async Task HandleShare(UpdateItem item)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", "Check out: " + item.Title);
        item.ShareCopied = true;
        StateHasChanged();
        await Task.Delay(1800);
        item.ShareCopied = false;
        StateHasChanged();
    }

    // ── Comments ───────────────────────────────────────────────

    private void ToggleComments(UpdateItem item)    => item.ShowComments = !item.ShowComments;

    private void ShowMoreComments(UpdateItem item)  =>
        item.VisibleComments = Math.Min(item.VisibleComments + 2, item.Comments.Count);

    private async Task ToggleCommentLike(CommentItem c)
    {
        try
        {
            var result = await DiaryService.ToggleCommentLikeAsync(c.Id);
            c.Liked     = result.Liked;
            c.LikeCount = result.LikeCount;
        }
        catch { }
    }

    private async Task AddComment(UpdateItem item)
    {
        var text = item.NewCommentText?.Trim();
        if (string.IsNullOrEmpty(text)) return;

        try
        {
            var comment = await DiaryService.AddCommentAsync(item.Id, text);
            if (comment != null)
            {
                item.Comments.Insert(0, new CommentItem
                {
                    Id         = comment.Id,
                    Author     = comment.Author,
                    ProfileImg = comment.ProfileImg,
                    Text       = comment.Text,
                    CreatedAt  = comment.CreatedAt
                });
            }
        }
        catch
        {
            item.Comments.Insert(0, new CommentItem
                { Author = currentUser?.DisplayName ?? "You", Text = text, CreatedAt = DateTime.UtcNow });
        }

        item.NewCommentText = string.Empty;
        // ensure new comment is visible
        if (item.VisibleComments < item.Comments.Count)
            item.VisibleComments = Math.Min(item.VisibleComments + 1, item.Comments.Count);
    }

    // ── Emoji picker (JS interop) ──────────────────────────────

    private async Task OpenEmojiPicker(UpdateItem item)
    {
        await JS.InvokeVoidAsync(
            "emojiPicker.show",
            _dotNetRef,
            $"emoji-anchor-{item.Id}",
            $"comment-input-{item.Id}"
        );
    }

    [JSInvokable]
    public void OnEmojiSelected(string inputId, string emoji)
    {
        var idStr = inputId.Replace("comment-input-", "");
        if (!int.TryParse(idStr, out var postId)) return;

        var item = updates.FirstOrDefault(u => u.Id == postId);
        if (item is null) return;

        item.NewCommentText = (item.NewCommentText ?? "") + emoji;
        StateHasChanged();
    }

    // ── Helpers ────────────────────────────────────────────────

    private static string TimeAgo(DateTime date)
    {
        var utc  = date.Kind == DateTimeKind.Utc ? date : date.ToUniversalTime();
        var diff = (DateTime.UtcNow - utc).TotalSeconds;
        if (diff < 60)      return "just now";
        if (diff < 3600)    return $"{(int)(diff / 60)}m ago";
        if (diff < 86400)   return $"{(int)(diff / 3600)}h ago";
        if (diff < 604800)  return $"{(int)(diff / 86400)}d ago";
        return date.ToString("MMM d");
    }

    private static string GetAvatarInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : parts[0][0].ToString().ToUpper();
    }

    public void Dispose() => _dotNetRef?.Dispose();

    // ── Models ─────────────────────────────────────────────────

    private sealed class UpdateItem
    {
        public int    Id            { get; set; }
        public string Title         { get; set; } = "";
        public string Description   { get; set; } = "";
        public string Author        { get; set; } = "";
        public DateTime CreatedAt   { get; set; }
        public string ImageUrl      { get; set; } = "";
        public string VideoUrl      { get; set; } = "";
        public List<string> ImageUrls { get; set; } = new();
        public int    GalleryIndex  { get; set; }
        public bool   IsExpanded    { get; set; }
        public bool   NeedsReadMore { get; set; }
        public bool   ShowComments  { get; set; }
        public bool   ShareCopied   { get; set; }
        public int    VisibleComments { get; set; } = 2;
        public string NewCommentText  { get; set; } = "";
        public List<CommentItem> Comments { get; set; } = new();
        public Dictionary<string, int> ReactionCounts { get; set; } =
            new() { {"heart",0}, {"fire",0}, {"bulb",0}, {"clap",0} };
        public List<string> Reacted { get; set; } = new();
        public string[] GalleryBackgrounds => Explore.GalleryBackgrounds;
    }

    private sealed class CommentItem
    {
        public int     Id         { get; set; }
        public string  Author     { get; set; } = "";
        public string? ProfileImg { get; set; }
        public string  Text       { get; set; } = "";
        public DateTime CreatedAt { get; set; }
        public bool    Liked      { get; set; }
        public int     LikeCount  { get; set; }
    }

    private sealed class NewsPostDto
    {
        public int     Id        { get; set; }
        public string  Title     { get; set; } = "";
        public string  Content   { get; set; } = "";
        public string  ImageUrl  { get; set; } = "";
        public string  VideoUrl  { get; set; } = "";
        public string  Author    { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
