@page "/diary/{Id:int}"
@inject DiaryService DiaryService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>@(entry?.Title ?? "Loading...") - Diary Me</PageTitle>

<div class="diary-detail-page">
    <div class="diary-page">

        <!-- TOP ACTIONS -->
        <div class="top-actions">
            <button class="btn-back" @onclick="GoBack">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Back to List
            </button>
            <div class="action-group">
                <!-- Share button -->
                <div class="share-wrapper">
                    <button class="btn-share" @onclick="ToggleShareMenu">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                        </svg>
                        Share
                    </button>

                    @if (showShareMenu)
                    {
                        <div class="share-dropdown">
                            <!-- Image card -->
                            <button class="share-item" @onclick="ShareAsImage">
                                <span class="share-icon si-image">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                                        <circle cx="8.5" cy="8.5" r="1.5"/>
                                        <polyline points="21 15 16 10 5 21"/>
                                    </svg>
                                </span>
                                <div>
                                    <div class="share-item-title">Share as image card</div>
                                    <div class="share-item-desc">Beautiful card for Instagram &amp; more</div>
                                </div>
                            </button>

                            <div class="share-divider"></div>

                            <!-- WhatsApp -->
                            <button class="share-item" @onclick="ShareWhatsApp">
                                <span class="share-icon si-wa">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="#25d366">
                                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                                    </svg>
                                </span>
                                <div>
                                    <div class="share-item-title">WhatsApp</div>
                                    <div class="share-item-desc">Share via WhatsApp</div>
                                </div>
                            </button>

                            <!-- Telegram -->
                            <button class="share-item" @onclick="ShareTelegram">
                                <span class="share-icon si-tg">
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="#0088cc">
                                        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
                                    </svg>
                                </span>
                                <div>
                                    <div class="share-item-title">Telegram</div>
                                    <div class="share-item-desc">Share via Telegram</div>
                                </div>
                            </button>
                        </div>
                    }
                </div>

                <button class="btn-edit" @onclick="EditEntry">Edit Entry</button>
                <button class="btn-delete" @onclick="DeleteEntry">Delete</button>
            </div>
        </div>

        <!-- TOAST NOTIFICATION -->
        @if (!string.IsNullOrEmpty(toastMessage))
        {
            <div class="toast @(toastVisible ? "toast-show" : "")">@toastMessage</div>
        }

        @if (entry == null)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Retrieving your memory...</p>
            </div>
        }
        else
        {
            <!-- HIDDEN IMAGE CARD (rendered off-screen, captured by html2canvas) -->
            <div id="share-card" class="share-card-hidden">
                <div class="sc-watermark">Diary Me</div>
                <div class="sc-date">@entry.Date.ToString("dddd, MMMM d, yyyy")</div>
                <div class="sc-title">@entry.Title</div>
                @if (!string.IsNullOrEmpty(entry.Location) || !string.IsNullOrEmpty(entry.Weather) || !string.IsNullOrEmpty(entry.Mood))
                {
                    <div class="sc-pills">
                        @if (!string.IsNullOrEmpty(entry.Location))  { <span class="sc-pill">📍 @entry.Location</span> }
                        @if (!string.IsNullOrEmpty(entry.Weather))   { <span class="sc-pill">⛅ @entry.Weather</span> }
                        @if (!string.IsNullOrEmpty(entry.Mood))      { <span class="sc-pill">@GetMoodEmoji(entry.Mood) @entry.Mood</span> }
                    </div>
                }
                <div class="sc-excerpt">
                    "@GetExcerpt(entry.Content, 180)"
                </div>
                <div class="sc-footer">
                    <span>diarymeapp.com</span>
                    <span>@entry.Date.ToString("yyyy")</span>
                </div>
            </div>

            <article class="journal-page">

                <header class="journal-header">
                    <div class="journal-dateline">
                        <div class="date-badge">
                            <span class="date-badge-day">@entry.Date.ToString("dd")</span>
                            <span class="date-badge-month">@entry.Date.ToString("MMM").ToUpper()</span>
                        </div>
                        <div class="date-info">
                            <span class="date-full">@entry.Date.ToString("dddd, MMMM d, yyyy")</span>
                            <span class="date-time">@entry.Date.ToString("h:mm tt")</span>
                        </div>
                    </div>

                    <h1 class="journal-title">@entry.Title</h1>

                    @if (!string.IsNullOrEmpty(entry.Location) || !string.IsNullOrEmpty(entry.Weather) || !string.IsNullOrEmpty(entry.Mood))
                    {
                        <div class="context-ribbon">
                            @if (!string.IsNullOrEmpty(entry.Location))
                            {
                                <span class="context-pill">📍 @entry.Location</span>
                            }
                            @if (!string.IsNullOrEmpty(entry.Weather))
                            {
                                <span class="context-pill">⛅ @entry.Weather</span>
                            }
                            @if (!string.IsNullOrEmpty(entry.Mood))
                            {
                                <span class="context-pill">@GetMoodEmoji(entry.Mood) @entry.Mood</span>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(entry.Tags))
                    {
                        <div class="tags-row">
                            @foreach (var tag in entry.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="tag">@tag.Trim()</span>
                            }
                        </div>

                        <div class="stats-grid">
                            <div class="stat-card">
                                <div class="stat-icon-wrap words">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                                </div>
                                <div class="stat-info">
                                    <span class="stat-value">@GetWordCount(entry.Content)</span>
                                    <span class="stat-label">Words written</span>
                                </div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-icon-wrap reading">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                </div>
                                <div class="stat-info">
                                    <span class="stat-value">@GetReadTime(entry.Content) min</span>
                                    <span class="stat-label">Reading time</span>
                                </div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-icon-wrap chars">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
                                </div>
                                <div class="stat-info">
                                    <span class="stat-value">@GetCharCount(entry.Content)</span>
                                    <span class="stat-label">Characters</span>
                                </div>
                            </div>
                        </div>
                    }
                </header>

                <div class="header-rule"></div>

                @if (!string.IsNullOrEmpty(entry.ImageUrls))
                {
                    <div class="journal-gallery">
                        @foreach (var url in entry.ImageUrls.Split(';', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <div class="gallery-item">
                                <img src="@($"http://localhost:5105{url}")" alt="@entry.Title" @onclick="() => OpenImage(url)" />
                            </div>
                        }
                    </div>
                }

                <div class="journal-body">
                    <div class="body-inner">
                        @((MarkupString)entry.Content)
                    </div>
                </div>

                <div class="journal-footer">
                    <div class="footer-quill">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/>
                            <line x1="16" y1="8" x2="2" y2="22"/>
                            <line x1="17.5" y1="15" x2="9" y2="15"/>
                        </svg>
                    </div>
                    <span class="footer-text">Written on @entry.Date.ToString("MMMM d, yyyy") · Diary Me</span>
                </div>

            </article>
        }

    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private DiaryEntry? entry;
    private bool showShareMenu  = false;
    private string toastMessage = "";
    private bool toastVisible   = false;
    private System.Threading.CancellationTokenSource? _toastCts;

    protected override async Task OnInitializedAsync()
    {
        entry = await DiaryService.GetEntryByIdAsync(Id);
    }

    // ── Share menu toggle ─────────────────────────────────────────────────────
    private void ToggleShareMenu() => showShareMenu = !showShareMenu;

    // ── Share as image card (html2canvas) ─────────────────────────────────────
    private async Task ShareAsImage()
    {
        showShareMenu = false;
        await JSRuntime.InvokeVoidAsync("DiaryShare.captureAndDownload", "share-card", $"diary-{entry?.Title ?? "entry"}.png");
        await ShowToast("📸 Image saved!");
    }

    // ── WhatsApp ──────────────────────────────────────────────────────────────
    private async Task ShareWhatsApp()
    {
        showShareMenu = false;
        if (entry == null) return;
        var text = Uri.EscapeDataString($"📖 {entry.Title}\n\n{GetExcerpt(entry.Content, 200)}\n\n— Diary Me");
        await JSRuntime.InvokeVoidAsync("open", $"https://wa.me/?text={text}", "_blank");
        await ShowToast("💬 Opening WhatsApp...");
    }

    // ── Telegram ──────────────────────────────────────────────────────────────
    private async Task ShareTelegram()
    {
        showShareMenu = false;
        if (entry == null) return;
        var text = Uri.EscapeDataString($"📖 {entry.Title}\n\n{GetExcerpt(entry.Content, 200)}\n\n— Diary Me");
        await JSRuntime.InvokeVoidAsync("open", $"https://t.me/share/url?url={Uri.EscapeDataString(NavigationManager.Uri)}&text={text}", "_blank");
        await ShowToast("✈️ Opening Telegram...");
    }

    // ── Toast helper ──────────────────────────────────────────────────────────
    private async Task ShowToast(string msg)
    {
        _toastCts?.Cancel();
        _toastCts = new System.Threading.CancellationTokenSource();
        toastMessage = msg;
        toastVisible = true;
        StateHasChanged();
        try
        {
            await Task.Delay(2600, _toastCts.Token);
            toastVisible = false;
            StateHasChanged();
            await Task.Delay(400, _toastCts.Token);
            toastMessage = "";
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    // ── Navigation / delete ───────────────────────────────────────────────────
    private void GoBack()    => NavigationManager.NavigateTo("/diary");
    private void EditEntry() => NavigationManager.NavigateTo($"/diary/edit/{Id}");

    private async Task DeleteEntry()
    {
        if (entry == null) return;
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete \"{entry.Title}\"?");
        if (confirmed)
        {
            await DiaryService.DeleteEntryAsync(entry);
            NavigationManager.NavigateTo("/diary");
        }
    }

    private async Task OpenImage(string url) =>
        await JSRuntime.InvokeVoidAsync("open", $"http://localhost:5105{url}", "_blank");

    // ── Helpers ───────────────────────────────────────────────────────────────
    private static string GetMoodEmoji(string mood) => mood.ToLower() switch
    {
        "terrible" => "😢", "bad" => "😕", "okay" => "😐", "good" => "😊", "amazing" => "✨", _ => "😊"
    };

    private static readonly System.Text.RegularExpressions.Regex _htmlTagRegex =
        new System.Text.RegularExpressions.Regex("<[^>]*>", System.Text.RegularExpressions.RegexOptions.Compiled);

    private static string StripHtml(string html) =>
        string.IsNullOrEmpty(html) ? string.Empty : _htmlTagRegex.Replace(html, " ");

    private static int GetWordCount(string html) =>
        StripHtml(html).Trim() is { Length: > 0 } t
            ? t.Split(new[] { ' ', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries).Length : 0;

    private static int GetReadTime(string html)  => Math.Max(1, (int)Math.Ceiling(GetWordCount(html) / 200.0));
    private static int GetCharCount(string html)  => string.IsNullOrEmpty(html) ? 0 : StripHtml(html).Length;

    private static string GetExcerpt(string html, int maxChars)
    {
        var text = StripHtml(html).Trim();
        return text.Length <= maxChars ? text : text[..maxChars].TrimEnd() + "…";
    }
}
